# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Cargo.lock is committed for executables (ensures reproducible builds).
# See: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can generally be ignored
*.pdb
*.lib
*.exp
*.ilk

# MacOS
.DS_Store

# Logs
logs/
*.log

# Configurations and Secrets
config.toml
.env
secret.key

# Internal planning files (not for public)
TASKS.md

# Databases and Local State
*.db
*.db-shm
*.db-wal
memory.db
workspace/
.adaclaw/
